<?xml version="1.0" encoding="UTF-8"?>
<suppressions xmlns="https://jeremylong.github.io/DependencyCheck/dependency-suppression.1.3.xsd">
    <!--
        v1.1 Batch 3: OWASP dependency-check suppression file.

        Add entries here ONLY after triaging the finding. Format:

        <suppress>
            <notes><![CDATA[
                Why this is suppressed (links to upstream issue, fixed-in
                version, mitigation, sign-off, etc.).
            ]]></notes>
            <packageUrl regex="true">^pkg:maven/<group>/<artifact>@.*$</packageUrl>
            <cve>CVE-YYYY-NNNNN</cve>
        </suppress>

        Empty file is fine — dependencyCheck will simply find no
        suppressions and apply its default fail-on-CVSS-7 threshold.
    -->
</suppressions>
