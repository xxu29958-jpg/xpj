DATABASE_URL=postgresql+psycopg://ticketbox:replace-with-strong-password@localhost:5432/ticketbox
UPLOAD_DIR=uploads
MAX_UPLOAD_SIZE_MB=10
DELETE_IMAGE_AFTER_CONFIRM=false
GENERATE_THUMBNAIL=true
DELETE_IMAGE_AFTER_DAYS=0
DELETE_REJECTED_AFTER_DAYS=0
ORPHAN_UPLOAD_GRACE_HOURS=24
OCR_PROVIDER=empty
OCR_AUTO_RUN=false
OCR_FALLBACK_PROVIDER=empty
OCR_MIN_CONFIDENCE=0.65
OCR_DEFAULT_TIMEZONE=Asia/Shanghai
LOCAL_LLM_BASE_URL=http://127.0.0.1:1234/v1
LOCAL_LLM_MODEL=
LOCAL_LLM_TIMEOUT_SECONDS=60

# AI budget advisor is suggestion-only and defaults to local rules / no outbound.
# Public providers require HTTPS + API key. Local/private OpenAI-compatible
# endpoints may omit the key.
# BUDGET_ADVISOR_PROVIDER=empty
# BUDGET_ADVISOR_BASE_URL=
# BUDGET_ADVISOR_API_KEY=
# BUDGET_ADVISOR_MODEL=
# BUDGET_ADVISOR_TIMEOUT_SECONDS=60
# BUDGET_ADVISOR_AUDIT_RETENTION_DAYS=180
# BUDGET_ADVISOR_AUDIT_CLEANUP_AUTO_ENABLED=false
# BUDGET_ADVISOR_AUDIT_CLEANUP_DAILY_AT=03:45
# BUDGET_ADVISOR_AUDIT_CLEANUP_TIMEZONE=Asia/Shanghai
# BUDGET_ADVISOR_LIVE_MIN_INTERVAL_SECONDS=60
# BUDGET_ADVISOR_LIVE_DAILY_CALL_LIMIT=50

# v0.3 identity credentials are generated by bootstrap and stored hashed in the database.
# Do not configure APP_TOKEN / UPLOAD_TOKEN / ADMIN_TOKEN as runtime credentials.
# Existing deployments may keep old values during migration only; runtime requests
# using those legacy tokens return legacy_auth_removed.

# Optional migration source only. TENANTS_JSON is not a runtime tenant registry in v0.3.
# TENANTS_JSON=[{"id":"owner","name":"我的小票夹"},{"id":"tester_1","name":"灰度用户1"}]

# HTTP bootstrap of /api/bootstrap/owner is disabled by default. Cloudflare Tunnel
# loopback is NOT a privilege check. Only enable for one-shot HTTP bootstrap on a
# trusted local environment. See docs/runbook/BOOTSTRAP.md.
# ENABLE_HTTP_BOOTSTRAP=false
# HTTP_BOOTSTRAP_SECRET=

# v0.3-rc1-preflight: public boundary hardening.
# /docs /redoc /openapi.json are off by default to avoid leaking schema on
# Cloudflare Tunnel. Set to true only on a trusted local environment.
ENABLE_API_DOCS=false
# ⚠⚠⚠ DANGEROUS — DO NOT ENABLE FOR SELF-USE ⚠⚠⚠
# /api/admin/* and /owner are blocked when accessed via a public Host header
# (e.g. your tunnel domain) regardless of TCP peer. Setting this to true lifts
# the block for /api/admin/* (still requires a valid admin token). Owner Console
# is always loopback-only and ignores this flag.
#
# If you ever flip this to true, you have widened the public attack surface to
# "any device that has the admin token". Treat the admin token like a database
# password: rotate immediately if it leaks, and only enable this when you have
# additional protections (mTLS, IP allowlist, WAF) in front of the tunnel.
ALLOW_PUBLIC_ADMIN_API=false

# Public base URL of the Cloudflare Tunnel (or other reverse proxy) that fronts
# this backend. Owner Console uses it to compose the FULL public upload URL for
# iPhone Shortcut; the URL action only accepts absolute URLs. Must start with
# http:// or https:// and have no trailing slash. Leave empty to disable the
# full-URL hint (Owner Console will show a warning instead of a usable URL).
# PUBLIC_BASE_URL=https://api.example.com

# UploadLink is a URL credential for iPhone Shortcuts. New/rotated links expire
# after this many days and old database rows are backfilled on startup.
# UPLOAD_LINK_TTL_DAYS=90

# Optional Cloudflare Access origin verification for the public /web browser
# surface. Production four-layer deployment should enable this for /web/* and
# /static/web|shared/*, while Android/iPhone API flows continue to use the
# backend's own token model. Team domain must be the Cloudflare Access origin,
# for example https://family.cloudflareaccess.com.
CLOUDFLARE_ACCESS_REQUIRED=false
# CLOUDFLARE_ACCESS_TEAM_DOMAIN=https://family.cloudflareaccess.com
# CLOUDFLARE_ACCESS_AUD=

# v0.6+ multi-currency / FX rate sync. All optional — sane defaults apply.
# FX_HOME_CURRENCY_CODE: 基准币种，统计与报表都换算到这里. Default: CNY.
# FX_HOME_CURRENCY_CODE=CNY
# FX_SUPPORTED_CURRENCY_CODES: 用户可选币种 (逗号分隔). Default: 主流 12 种.
# FX_SUPPORTED_CURRENCY_CODES=CNY,USD,EUR,GBP,JPY,HKD,SGD,AUD,CAD,KRW,TWD,CHF
# FX_RATE_AUTO_SYNC_ENABLED: 是否启动 ECB FX 后台同步线程. Default: true.
# FX_RATE_AUTO_SYNC_ENABLED=true
# FX_RATE_SYNC_TIMES: 24h 时刻列表 (逗号分隔 HH:MM). Default: 09:10,23:10.
# FX_RATE_SYNC_TIMES=09:10,23:10
# FX_RATE_SYNC_TIMEZONE: 同步时间所属时区. Default: Asia/Shanghai.
# FX_RATE_SYNC_TIMEZONE=Asia/Shanghai
# FX_RATE_SOURCE: 汇率传输源. frankfurter (默认, ECB 数据镜像, 免 key, 国内可达) 或 ecb (europa.eu 直连).
# FX_RATE_SOURCE=frankfurter
# FX_RATE_FRANKFURTER_URL: Frankfurter JSON 数据源. Default: 官方 v1/latest.
# FX_RATE_FRANKFURTER_URL=https://api.frankfurter.dev/v1/latest?base=EUR
# FX_RATE_ECB_URL: ECB FX rate XML 数据源 (仅当 FX_RATE_SOURCE=ecb). Default: 官方 eurofxref-daily.xml.
# FX_RATE_ECB_URL=https://www.ecb.europa.eu/stats/eurofxref/eurofxref-daily.xml

# ADR-0049 Debt domain rollout. ON by default (⑤b activation): accepting a
# bill-split invitation creates the receiver's member Debt. All prerequisites are
# met — slice 5 account-scoped participant confirm/reject (§5.2), cross-ledger
# creditor discovery + confirm UX across all three surfaces, and startup backfill
# self-heal for splits accepted before rollout. Forward-only per ADR-0049 §4 /
# §0.1. Set to false to opt this install out (does not remove existing Debts).
# DEBT_ROLLOUT_ENABLED=true
